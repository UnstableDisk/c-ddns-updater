#include <stdio.h>
#include <string.h>

#include "config.h"
#include "namecom.h"
#include "ip.h"

int main(void) {
    char ip[64];
    char records_json[16384] = {0};
    Config config;

    printf("===================================\n");
    printf("   C DDNS Updater v0.1.0\n");
    printf("===================================\n");

    if (load_config("configs/ddns.conf", &config) != 0) {
        prontf("Failed to load config.\n");
        return 1;
    }

    if (get_public_ip(ip, sizeof(ip)) != 0) {
        printf("Failed to get public IP.\n");
        return 1;
    }

    if (namecom_listrecords(&config, records_json, sizeof(records_json) != 0) {
        printf("Failed to list Name.com DNS records.\n");
        return 1;
    }

    

    printf("Public IP: %s\n", ip);

    return 0;
}
